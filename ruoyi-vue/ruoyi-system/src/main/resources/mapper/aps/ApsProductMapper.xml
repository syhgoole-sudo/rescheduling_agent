<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.aps.mapper.ApsProductMapper">

    <resultMap type="com.ruoyi.aps.domain.ApsProduct" id="ApsProductResult">
        <id property="productId" column="product_id" />
        <result property="productCode" column="product_code" />
        <result property="productName" column="product_name" />
        <result property="status" column="status" />
        <result property="delFlag" column="del_flag" />
        <result property="createBy" column="create_by" />
        <result property="createTime" column="create_time" />
        <result property="updateBy" column="update_by" />
        <result property="updateTime" column="update_time" />
        <result property="remark" column="remark" />
    </resultMap>

    <sql id="selectApsProductVo">
        select product_id, product_code, product_name, status, del_flag, create_by, create_time, update_by, update_time, remark from aps_product
    </sql>

    <select id="selectApsProductList" parameterType="com.ruoyi.aps.domain.ApsProduct" resultMap="ApsProductResult">
        <include refid="selectApsProductVo"/>
        <where>
            <if test="productCode != null and productCode != ''"> and product_code like concat('%', #{productCode}, '%')</if>
            <if test="productName != null and productName != ''"> and product_name like concat('%', #{productName}, '%')</if>
            <if test="status != null and status != ''"> and status like concat('%', #{status}, '%')</if>
        </where>
    </select>

    <select id="selectApsProductById" parameterType="Long" resultMap="ApsProductResult">
        <include refid="selectApsProductVo"/>
        where product_id = #{productId}
    </select>

    <insert id="insertApsProduct" parameterType="com.ruoyi.aps.domain.ApsProduct" useGeneratedKeys="true" keyProperty="productId">
        insert into aps_product
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="productCode != null">product_code,</if>
            <if test="productName != null">product_name,</if>
            <if test="status != null">status,</if>
            <if test="delFlag != null">del_flag,</if>
            <if test="createBy != null">create_by,</if>
            <if test="remark != null">remark,</if>
            create_time
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="productCode != null">#{productCode},</if>
            <if test="productName != null">#{productName},</if>
            <if test="status != null">#{status},</if>
            <if test="delFlag != null">#{delFlag},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="remark != null">#{remark},</if>
            sysdate()
        </trim>
    </insert>

    <update id="updateApsProduct" parameterType="com.ruoyi.aps.domain.ApsProduct">
        update aps_product
        <trim prefix="SET" suffixOverrides=",">
            <if test="productCode != null">product_code = #{productCode},</if>
            <if test="productName != null">product_name = #{productName},</if>
            <if test="status != null">status = #{status},</if>
            <if test="delFlag != null">del_flag = #{delFlag},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="remark != null">remark = #{remark},</if>
            update_time = sysdate()
        </trim>
        where product_id = #{productId}
    </update>

    <delete id="deleteApsProductById" parameterType="Long">
        delete from aps_product where product_id = #{productId}
    </delete>

    <delete id="deleteApsProductByIds" parameterType="Long">
        delete from aps_product where product_id in
        <foreach item="productId" collection="array" open="(" separator="," close=")">
            #{productId}
        </foreach>
    </delete>
</mapper>
