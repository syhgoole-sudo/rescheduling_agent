            <if test="plannedStartTime != null">#{plannedStartTime},</if>
            <if test="plannedEndTime != null">#{plannedEndTime},</if>
            <if test="duration != null">#{duration},</if>
            <if test="taskStatus != null">#{taskStatus},</if>
            <if test="isFrozen != null">#{isFrozen},</if>
