            <if test="isFrozen != null">is_frozen,</if>
            <if test="isInserted != null">is_inserted,</if>
            <if test="isChanged != null">is_changed,</if>
            <if test="sourceTaskId != null">source_task_id,</if>
            <if test="originalStartTime != null">original_start_time,</if>
            <if test="originalEndTime != null">original_end_time,</if>
            <if test="originalEquipmentId != null">original_equipment_id,</if>
            <if test="delFlag != null">del_flag,</if>
            <if test="createBy != null">create_by,</if>
            <if test="remark != null">remark,</if>
            create_time
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="planId != null">#{planId},</if>
            <if test="orderId != null">#{orderId},</if>
