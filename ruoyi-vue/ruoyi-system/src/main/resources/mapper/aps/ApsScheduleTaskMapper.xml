    </resultMap>

    <sql id="selectApsScheduleTaskVo">
        select task_id, plan_id, order_id, order_code, product_id, product_code, process_seq, process_code, process_name, equipment_group_id, equipment_id, equipment_code, planned_start_time, planned_end_time, duration, task_status, is_frozen, is_inserted, is_changed, source_task_id, original_start_time, original_end_time, original_equipment_id, del_flag, create_by, create_time, update_by, update_time, remark from aps_schedule_task
    </sql>

    <select id="selectApsScheduleTaskList" parameterType="com.ruoyi.aps.domain.ApsScheduleTask" resultMap="ApsScheduleTaskResult">
        <include refid="selectApsScheduleTaskVo"/>
        <where>
            <if test="planId != null"> and plan_id = #{planId}</if>
            <if test="orderId != null"> and order_id = #{orderId}</if>
            <if test="orderCode != null and orderCode != ''"> and order_code like concat('%', #{orderCode}, '%')</if>
            <if test="equipmentId != null"> and equipment_id = #{equipmentId}</if>
            <if test="taskStatus != null and taskStatus != ''"> and task_status like concat('%', #{taskStatus}, '%')</if>
        </where>
        order by equipment_id asc, planned_start_time asc, process_seq asc
    </select>

    <select id="selectApsScheduleTaskById" parameterType="Long" resultMap="ApsScheduleTaskResult">
        <include refid="selectApsScheduleTaskVo"/>
        where task_id = #{taskId}
    </select>

    <select id="selectApsScheduleTaskListByPlanId" parameterType="Long" resultMap="ApsScheduleTaskResult">
        <include refid="selectApsScheduleTaskVo"/>
        where plan_id = #{planId}
          and (del_flag = '0' or del_flag is null)
        order by equipment_id asc, planned_start_time asc, process_seq asc
    </select>

    <select id="selectAffectedTasks" resultMap="ApsScheduleTaskResult">
        <include refid="selectApsScheduleTaskVo"/>
        where plan_id = #{planId}
          and planned_start_time is not null
          and planned_end_time is not null
          and planned_start_time &lt; #{impactWindowEnd}
          and planned_end_time &gt; #{impactWindowStart}
          and (task_status is null or task_status not in ('COMPLETED', 'FINISHED', 'DONE', 'CANCELLED'))
          and (del_flag = '0' or del_flag is null)
          <if test="equipmentGroupIds != null and equipmentGroupIds.size() > 0">
              and equipment_group_id in
              <foreach item="equipmentGroupId" collection="equipmentGroupIds" open="(" separator="," close=")">
                  #{equipmentGroupId}
              </foreach>
          </if>
        order by equipment_id asc, planned_start_time asc, process_seq asc
    </select>

    <insert id="insertApsScheduleTask" parameterType="com.ruoyi.aps.domain.ApsScheduleTask" useGeneratedKeys="true" keyProperty="taskId">
        insert into aps_schedule_task
        <trim prefix="(" suffix=")" suffixOverrides=",">
